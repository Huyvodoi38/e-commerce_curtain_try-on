# Cấu hình MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=curtain_shop

# Cấu hình ứng dụng
APP_NAME="AI Curtain Shop"
APP_ENV=development
SECRET_KEY=change-me-in-production

# CORS (danh sách origin cách nhau bởi dấu phẩy)
CORS_ORIGINS=http://localhost:3000

# --------------------------------------------------------
# AI Engine (Try-on rèm)
# --------------------------------------------------------
# Bật/tắt toàn bộ tính năng AI. Khi = false:
#   - Endpoint /ai/tryon trả về 503.
#   - Backend KHÔNG cần cài torch/diffusers/SAM (chỉ cần requirements.txt).
AI_ENABLED=false

# Khi AI_ENABLED=true, có preload model ngay lúc server start hay không.
# Đặt false để startup nhanh, model sẽ được load lazy ở request đầu tiên.
LOAD_AI_ON_STARTUP=false

# Cấu hình model (chỉ dùng khi AI_ENABLED=true)
SAM_CHECKPOINT=models/sam_vit_b_01ec64.pth
SAM_MODEL_TYPE=vit_b
SD_MODEL_ID=Uminosachi/realisticVisionV51_v51VAE-inpainting
CONTROLNET_MODEL_ID=lllyasviel/control_v11f1p_sd15_depth
DEPTH_MODEL_ID=Intel/dpt-large
