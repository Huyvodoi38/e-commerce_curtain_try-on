MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=Curtain_AI_TryOn
# Test: copy .env.test.example -> .env.test (DB rieng, vd. Curtain_AI_TryOn_test)
PROJECT_NAME=Quang Huy Shop
BEANIE_ALLOW_INDEX_DROPPING=true

SECRET_KEY=thay-bang-chuoi-ngau-nhien-dai-it-nhat-32-ky-tu
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Dev (Vite proxy, 1 origin) ---
BACKEND_URL=http://127.0.0.1:8000
# Phải trùng URL bạn mở trên trình duyệt (dev thường dùng localhost)
FRONTEND_URL=http://localhost:5173
# Để trống = callback qua FE proxy: http://localhost:5173/auth/google/callback
# Đăng ký URI này trên Google Cloud Console → Credentials → OAuth 2.0 Client
GOOGLE_REDIRECT_URI=
CORS_ALLOW_ALL=true
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# Rate limit theo IP (mặc định true; test tự tắt qua .env.test/helpers)
RATE_LIMIT_ENABLED=true

# --- VNPay (Phase 4.2) — sandbox; IPN cần URL public (ngrok) ---
