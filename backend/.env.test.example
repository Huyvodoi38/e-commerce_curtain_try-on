# Copy -> .env.test (gitignore). Dùng cho pytest & reset_test_db.py
# Cùng cluster MongoDB nhưng TÊN DB khác — tránh xóa nhầm dữ liệu dev.

MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=Curtain_AI_TryOn_test
SECRET_KEY=pytest-secret-key-at-least-32-characters
BEANIE_ALLOW_INDEX_DROPPING=true
