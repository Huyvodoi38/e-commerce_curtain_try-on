# Production — 2 domain (FE app + API)
# Copy thành biến môi trường trên server / secret manager (không commit file thật)

MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=Curtain_AI_TryOn
BEANIE_ALLOW_INDEX_DROPPING=false

SECRET_KEY=<random-64-chars-minimum>
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

GOOGLE_CLIENT_ID=<production-client-id>
GOOGLE_CLIENT_SECRET=<production-client-secret>

# FE (static hosting)
FRONTEND_URL=https://app.example.com
# API (FastAPI)
BACKEND_URL=https://api.example.com
# Google redirect — trỏ thẳng API (đăng ký đúng URI này trên Google Console)
GOOGLE_REDIRECT_URI=https://api.example.com/auth/google/callback

# Chỉ allow FE production
CORS_ALLOW_ALL=false
COOKIE_SECURE=true
# Bắt buộc khi FE và API khác domain (cross-site cookie)
COOKIE_SAMESITE=none

# VNPay sandbox (URL public — không localhost)
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_EXPIRE_MINUTES=15
# IPN = BACKEND_URL + path
VNPAY_IPN_URL=https://api.example.com/payments/vnpay/ipn
# Return = FE Vercel
VNPAY_RETURN_URL_TEMPLATE=https://app.example.com/orders/{order_id}/pay/return

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER_PREFIX=curtain

# AI try-on (Colab + ngrok — cập nhật mỗi lần mở session)
# AI_SERVICE_URL=https://xxxx.ngrok-free.app
# AI_TRYON_TIMEOUT_SECONDS=120
